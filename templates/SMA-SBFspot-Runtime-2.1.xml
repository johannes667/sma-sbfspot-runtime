<?xml version="1.0"?>
<Container version="2">
  <Name>SMA-SBFspot-Runtime</Name>
  <Repository>ghcr.io/johannes667/sma-sbfspot-runtime:latest</Repository>
  <Registry>https://github.com/johannes667/sma-sbfspot-runtime</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/johannes667/sma-sbfspot-runtime/issues</Support>
  <Project>https://github.com/johannes667/sma-sbfspot-runtime</Project>
  <Overview>SMA SBFspot Runtime with Web UI, MQTT support and Unraid friendly paths.</Overview>
  <Category>Tools: Utilities: Network:HomeAutomation</Category>
  <WebUI>http://[IP]:[PORT:8088]</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/johannes667/sma-sbfspot-runtime/main/templates/SMA-SBFspot-Runtime-2.1.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/johannes667/sma-sbfspot-runtime/main/web/static/icon.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Requires/>
  <Config Name="WebUI Port" Target="8088" Default="8088" Mode="tcp" Description="Web interface port" Type="Port" Display="always" Required="true" Mask="false">8088</Config>
  <Config Name="Config Path" Target="/config" Default="/mnt/user/appdata/sma-sbfspot-runtime/config" Mode="rw" Description="Configuration directory" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/sma-sbfspot-runtime/config</Config>
  <Config Name="Data Path" Target="/data" Default="/mnt/user/appdata/sma-sbfspot-runtime/data" Mode="rw" Description="Data directory for logs, database or runtime files" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/sma-sbfspot-runtime/data</Config>
  <Config Name="Timezone" Target="TZ" Default="Europe/Berlin" Description="Container timezone" Type="Variable" Display="always" Required="true" Mask="false">Europe/Berlin</Config>
  <Config Name="SBFspot Interval" Target="INTERVAL" Default="300" Description="Polling interval in seconds" Type="Variable" Display="always" Required="true" Mask="false">300</Config>
  <Config Name="MQTT Enable" Target="MQTT_ENABLE" Default="true" Description="Enable MQTT publishing" Type="Variable" Display="always" Required="false" Mask="false">true</Config>
  <Config Name="MQTT Host" Target="MQTT_HOST" Default="192.168.2.122" Description="MQTT broker IP or hostname" Type="Variable" Display="always" Required="false" Mask="false">192.168.2.122</Config>
  <Config Name="MQTT Port" Target="MQTT_PORT" Default="1883" Description="MQTT broker port" Type="Variable" Display="always" Required="false" Mask="false">1883</Config>
  <Config Name="MQTT User" Target="MQTT_USER" Default="" Description="MQTT username" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="MQTT Password" Target="MQTT_PASSWORD" Default="" Description="MQTT password" Type="Variable" Display="always" Required="false" Mask="true"/>
  <Config Name="MQTT Topic Prefix" Target="MQTT_TOPIC_PREFIX" Default="sma" Description="MQTT topic prefix" Type="Variable" Display="always" Required="false" Mask="false">sma</Config>
</Container>
