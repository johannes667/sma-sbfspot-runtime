<?xml version="1.0"?>
<Container version="2">
  <Name>SMA-SBFspot-Runtime</Name>
  <Repository>local/sma-sbfspot-runtime:2.1</Repository>
  <Network>host</Network>
  <Privileged>true</Privileged>
  <Overview>SMA Bluetooth PV-Auslesung über SBFspot mit Web Dashboard, MQTT, Home Assistant Discovery, SQLite Historie und Healthcheck.</Overview>
  <Category>HomeAutomation: Tools:</Category>
  <WebUI>http://[IP]:[PORT:8088]/</WebUI>
  <ExtraParams>--restart unless-stopped</ExtraParams>
  <Config Name="Config" Target="/config" Default="/mnt/user/appdata/sma-sbfspot" Mode="rw" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/sma-sbfspot</Config>
  <Config Name="Data" Target="/data" Default="/mnt/user/appdata/sma-sbfspot/data" Mode="rw" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/sma-sbfspot/data</Config>
  <Config Name="DBus" Target="/var/run/dbus" Default="/var/run/dbus" Mode="rw" Type="Path" Display="advanced" Required="true" Mask="false">/var/run/dbus</Config>
  <Config Name="Interval" Target="INTERVAL" Default="300" Type="Variable" Display="always" Required="true" Mask="false">300</Config>
  <Config Name="MQTT Host" Target="MQTT_HOST" Default="192.168.2.115" Type="Variable" Display="always" Required="true" Mask="false">192.168.2.115</Config>
  <Config Name="MQTT User" Target="MQTT_USER" Default="sbfspot" Type="Variable" Display="always" Required="false" Mask="false">sbfspot</Config>
  <Config Name="MQTT Passwort" Target="MQTT_PASSWORD" Default="" Type="Variable" Display="always" Required="false" Mask="true"></Config>
  <Config Name="Device Name" Target="DEVICE_NAME" Default="SMA Wechselrichter Amann" Type="Variable" Display="always" Required="true" Mask="false">SMA Wechselrichter Amann</Config>
</Container>
